{
  "name": "ax-test-inventory",
  "version": "1.0.0",
  "description": "Inventory Management Library for Node.js — track items, stock levels, transactions, and generate reports",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "node --test 'test/unit/*.test.js' 'test/integration/*.test.js' 'test/scenarios/*.test.js'",
